<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema"
	xmlns:jxb="https://jakarta.ee/xml/ns/jaxb" jxb:version="3.0"
	xmlns:hpc-domain-lastaccess="http://hpc.nci.nih.gov/domain/lastaccess"
	targetNamespace="http://hpc.nci.nih.gov/domain/lastaccess"
	elementFormDefault="unqualified">

	<!-- Entry representing a last-access age bucket for the pie chart -->
	<xsd:complexType name="HpcLastAccessPieChartEntry">
		<xsd:sequence>
			<xsd:element name="bucketLabel" type="xsd:string" />
			<xsd:element name="bucketOrder" type="xsd:int" />
			<xsd:element name="fileCount" type="xsd:long" />
			<xsd:element name="percentage" type="xsd:double" />
		</xsd:sequence>
	</xsd:complexType>

	<!-- Entry representing a subfolder + last-access age bucket for the bar chart -->
	<xsd:complexType name="HpcLastAccessBarChartEntry">
		<xsd:sequence>
			<xsd:element name="subfolder" type="xsd:string" />
			<xsd:element name="bucketLabel" type="xsd:string" />
			<xsd:element name="bucketOrder" type="xsd:int" />
			<xsd:element name="fileCount" type="xsd:long" />
			<xsd:element name="percentage" type="xsd:double" />
		</xsd:sequence>
	</xsd:complexType>

</xsd:schema>
